<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Bai6 Retry Suite" parallel="tests" thread-count="2">
    <listeners>
        <listener class-name="framework.retry.RetryListener"/>
    </listeners>

    <test name="Retry-Demo-Dev">
        <parameter name="env" value="dev"/>
        <classes>
            <class name="tests.FlakySimulationTest"/>
        </classes>
    </test>

    <test name="Retry-Demo-Staging">
        <parameter name="env" value="staging"/>
        <classes>
            <class name="tests.FlakySimulationTest"/>
        </classes>
    </test>
</suite>
